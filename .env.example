# Copy this file to ".env" and fill in your Spotify API credentials.
# Create an app at https://developer.spotify.com/dashboard to get these.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Login is optional (only needed to convert your OWN private playlists in
# full). This redirect URI must EXACTLY match one in your Spotify app
# dashboard under "Redirect URIs". Local default:
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/callback
# In production: https://your-app.onrender.com/callback

# Signs session cookies (login). Use a long random value in production.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Optional: where finished files are written (defaults to ./downloads)
# DOWNLOAD_DIR=downloads

# Optional: Flask settings
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000
# FLASK_DEBUG=0
